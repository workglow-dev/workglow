{
  "name": "@workglow/cli",
  "type": "module",
  "version": "0.0.115",
  "description": "Command-line interface example for Workglow, demonstrating how to build and run AI task pipelines from the terminal.",
  "scripts": {
    "dev": "concurrently -c 'auto' -n 'cli:' 'npm:dev-*'",
    "dev-js": "SKIP_DTS=1 vite build --watch",
    "dev-types": "tsc --watch --preserveWatchOutput",
    "build-example": "vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bin": "./dist/workglow.js",
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "dependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "@huggingface/transformers": "catalog:",
    "tiktoken": "catalog:",
    "openai": "catalog:",
    "ollama": "catalog:",
    "node-llama-cpp": "catalog:",
    "@huggingface/inference": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "is-unicode-supported": "^2.1.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0",
    "react-devtools-core": "^7.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
