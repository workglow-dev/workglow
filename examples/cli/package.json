{
  "name": "@workglow/cli",
  "type": "module",
  "version": "0.2.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/workglow-dev/workglow.git",
    "directory": "examples/cli"
  },
  "description": "Command-line interface example for Workglow, demonstrating how to build and run AI task pipelines from the terminal.",
  "scripts": {
    "dev": "concurrently -c 'auto' -n 'cli:' 'bun:dev-*'",
    "dev-js": "bun build --watch --target=bun --sourcemap=external --packages=external --outdir ./dist ./src/workglow.ts",
    "dev-lib": "bun build --watch --target=bun --sourcemap=external --packages=external --outdir ./dist ./src/lib.ts",
    "dev-types": "tsc --watch --preserveWatchOutput",
    "build-example": "concurrently -c 'auto' -n 'js,js-worker-hft,lib,types' 'bun run build-js' 'bun run build-js-worker-hft' 'bun run build-lib' 'bun run build-types'",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-js": "bun build --target=bun --packages=external --outdir ./dist ./src/workglow.ts",
    "build-js-worker-hft": "bun build --target=node --packages=external --outdir ./dist ./src/worker_hft.ts",
    "build-lib": "bun build --target=bun --packages=external --outdir ./dist ./src/lib.ts",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsgo",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bin": "./dist/workglow.js",
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "exports": {
    ".": {
      "bun": "./dist/lib.js",
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "dependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "@huggingface/transformers": "catalog:",
    "tiktoken": "catalog:",
    "openai": "catalog:",
    "ollama": "catalog:",
    "node-llama-cpp": "catalog:",
    "@huggingface/inference": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "@napi-rs/keyring": "^1.1.2",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^7.0.0",
    "react": "^19.2.5",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
