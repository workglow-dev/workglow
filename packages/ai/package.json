{
  "name": "@workglow/ai",
  "type": "module",
  "version": "0.0.121",
  "description": "Core AI functionality for Workglow, including task execution, model management, and AI pipeline orchestration.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'bun:watch-*'",
    "watch-js": "concurrently -c 'auto' -n 'browser,node,bun,worker' 'bun run watch-browser' 'bun run watch-node' 'bun run watch-bun' 'bun run watch-worker'",
    "watch-browser": "bun build --splitting --watch --no-clear-screen --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/browser.ts",
    "watch-node": "bun build --splitting --watch --no-clear-screen --target=node --sourcemap=external --packages=external --outdir ./dist ./src/node.ts",
    "watch-bun": "bun build --splitting --watch --no-clear-screen --target=bun --sourcemap=external --packages=external --outdir ./dist ./src/bun.ts",
    "watch-worker": "bun build --splitting --watch --no-clear-screen --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/worker.ts",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "concurrently -c 'auto' -n 'browser,node,bun,worker,types' 'bun run build-browser' 'bun run build-node' 'bun run build-bun' 'bun run build-worker' 'bun run build-types'",
    "build-js": "concurrently -c 'auto' -n 'browser,node,bun,worker' 'bun run build-browser' 'bun run build-node' 'bun run build-bun' 'bun run build-worker'",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-browser": "bun build --splitting --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/browser.ts",
    "build-node": "bun build --splitting --target=node --sourcemap=external --packages=external --outdir ./dist ./src/node.ts",
    "build-bun": "bun build --splitting --target=bun --sourcemap=external --packages=external --outdir ./dist ./src/bun.ts",
    "build-worker": "bun build --splitting --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/worker.ts",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsgo",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun test"
  },
  "exports": {
    ".": {
      "react-native": "./src/browser.ts",
      "browser": "./src/browser.ts",
      "bun": "./src/bun.ts",
      "types": "./src/types.ts",
      "import": "./src/node.ts"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "import": "./src/worker.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@workglow/knowledge-base": {
      "optional": false
    },
    "@workglow/job-queue": {
      "optional": false
    },
    "@workglow/storage": {
      "optional": false
    },
    "@workglow/task-graph": {
      "optional": false
    },
    "@workglow/util": {
      "optional": false
    }
  },
  "devDependencies": {
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*"
  }
}