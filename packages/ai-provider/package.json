{
  "name": "@workglow/ai-provider",
  "type": "module",
  "sideEffects": false,
  "version": "0.0.110",
  "description": "AI provider integrations for Workglow, supporting OpenAI, Hugging Face Transformers, MediaPipe, and GGML models.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'bun:watch-*'",
    "watch-js": "concurrently -c 'auto' -n 'code,browser' 'bun run watch-code' 'bun run watch-browser'",
    "watch-code": "bun build --splitting --watch --no-clear-screen --sourcemap=external --packages=external --outdir ./dist ./src/index.ts ./src/anthropic/index.ts ./src/google-gemini/index.ts ./src/hf-transformers/index.ts ./src/provider-llamacpp/index.ts ./src/provider-hf-inference/index.ts ./src/provider-ollama/index.ts ./src/provider-openai/index.ts",
    "watch-browser": "bun build --splitting --watch --no-clear-screen --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/provider-ollama/index.browser.ts ./src/tf-mediapipe/index.ts",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "concurrently -c 'auto' -n 'code,browser,types' 'bun run build-code' 'bun run build-browser' 'bun run build-types'",
    "build-js": "concurrently -c 'auto' -n 'code,browser' 'bun run build-code' 'bun run build-browser'",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-code": "bun build --splitting --sourcemap=external --packages=external --outdir ./dist ./src/index.ts ./src/anthropic/index.ts ./src/google-gemini/index.ts ./src/hf-transformers/index.ts ./src/provider-llamacpp/index.ts ./src/provider-hf-inference/index.ts ./src/provider-ollama/index.ts ./src/provider-openai/index.ts",
    "build-browser": "bun build --splitting --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/provider-ollama/index.browser.ts ./src/tf-mediapipe/index.ts",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun test"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/index.js"
    },
    "./anthropic": {
      "bun": "./dist/anthropic/index.js",
      "types": "./dist/anthropic/index.d.ts",
      "import": "./dist/anthropic/index.js"
    },
    "./google-gemini": {
      "bun": "./dist/google-gemini/index.js",
      "types": "./dist/google-gemini/index.d.ts",
      "import": "./dist/google-gemini/index.js"
    },
    "./hf-transformers": {
      "bun": "./dist/hf-transformers/index.js",
      "types": "./dist/hf-transformers/index.d.ts",
      "import": "./dist/hf-transformers/index.js"
    },
    "./llamacpp": {
      "bun": "./dist/provider-llamacpp/index.js",
      "types": "./dist/provider-llamacpp/index.d.ts",
      "import": "./dist/provider-llamacpp/index.js"
    },
    "./ollama": {
      "browser": "./dist/provider-ollama/index.browser.js",
      "bun": "./dist/provider-ollama/index.js",
      "types": "./dist/provider-ollama/index.d.ts",
      "import": "./dist/provider-ollama/index.js"
    },
    "./openai": {
      "bun": "./dist/provider-openai/index.js",
      "types": "./dist/provider-openai/index.d.ts",
      "import": "./dist/provider-openai/index.js"
    },
    "./hf-inference": {
      "bun": "./dist/provider-hf-inference/index.js",
      "types": "./dist/provider-hf-inference/index.d.ts",
      "import": "./dist/provider-hf-inference/index.js"
    },
    "./tf-mediapipe": {
      "browser": "./dist/tf-mediapipe/index.js",
      "types": "./dist/tf-mediapipe/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*",
    "@huggingface/transformers": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "openai": "catalog:",
    "tiktoken": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "node-llama-cpp": "catalog:",
    "@huggingface/inference": "catalog:",
    "ollama": "catalog:"
  },
  "peerDependenciesMeta": {
    "@workglow/ai": {
      "optional": false
    },
    "@workglow/job-queue": {
      "optional": false
    },
    "@workglow/storage": {
      "optional": false
    },
    "@workglow/task-graph": {
      "optional": false
    },
    "@workglow/util": {
      "optional": false
    },
    "openai": {
      "optional": true
    },
    "tiktoken": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    },
    "ollama": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "@mediapipe/tasks-text": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    },
    "@mediapipe/tasks-audio": {
      "optional": true
    },
    "@mediapipe/tasks-genai": {
      "optional": true
    },
    "@huggingface/inference": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "@huggingface/inference": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@workglow/ai": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*",
    "node-llama-cpp": "catalog:",
    "ollama": "catalog:",
    "openai": "catalog:",
    "tiktoken": "catalog:"
  }
}
