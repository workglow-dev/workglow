{
  "name": "@workglow/ai-provider",
  "type": "module",
  "sideEffects": false,
  "version": "0.0.121",
  "description": "AI provider integrations for Workglow, supporting OpenAI, Hugging Face Transformers, MediaPipe, and GGML models.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'bun:watch-*'",
    "watch-js": "concurrently -c 'auto' -n 'code,browser' 'bun run watch-code' 'bun run watch-browser'",
    "watch-code": "bun build --watch --no-clear-screen --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/provider-anthropic/index.ts ./src/provider-anthropic/runtime.ts ./src/provider-gemini/index.ts ./src/provider-gemini/runtime.ts ./src/provider-hf-transformers/index.ts ./src/provider-hf-transformers/runtime.ts ./src/provider-llamacpp/index.ts ./src/provider-llamacpp/runtime.ts ./src/provider-hf-inference/index.ts ./src/provider-hf-inference/runtime.ts ./src/provider-ollama/index.ts ./src/provider-ollama/runtime.ts ./src/provider-openai/index.ts ./src/provider-openai/runtime.ts ./src/provider-chrome/index.ts ./src/provider-chrome/runtime.ts",
    "watch-browser": "bun build --watch --no-clear-screen --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/provider-ollama/index.browser.ts ./src/provider-ollama/runtime.browser.ts ./src/provider-tf-mediapipe/index.ts ./src/provider-tf-mediapipe/runtime.ts ./src/provider-chrome/index.ts",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "concurrently -c 'auto' -n 'code,browser,types' 'bun run build-code' 'bun run build-browser' 'bun run build-types'",
    "build-js": "concurrently -c 'auto' -n 'code,browser' 'bun run build-code' 'bun run build-browser'",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-code": "bun build --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/provider-anthropic/index.ts ./src/provider-anthropic/runtime.ts ./src/provider-gemini/index.ts ./src/provider-gemini/runtime.ts ./src/provider-hf-transformers/index.ts ./src/provider-hf-transformers/runtime.ts ./src/provider-llamacpp/index.ts ./src/provider-llamacpp/runtime.ts ./src/provider-hf-inference/index.ts ./src/provider-hf-inference/runtime.ts ./src/provider-ollama/index.ts ./src/provider-ollama/runtime.ts ./src/provider-openai/index.ts ./src/provider-openai/runtime.ts ./src/provider-chrome/index.ts ./src/provider-chrome/runtime.ts",
    "build-browser": "bun build --target=browser --sourcemap=external --packages=external --outdir ./dist ./src/provider-ollama/index.browser.ts ./src/provider-ollama/runtime.browser.ts ./src/provider-tf-mediapipe/index.ts ./src/provider-tf-mediapipe/runtime.ts ./src/provider-chrome/index.ts",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsgo",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun test"
  },
  "exports": {
    "./src/*": "./src/*",
    "./anthropic": {
      "types": "./src/provider-anthropic/index.ts",
      "import": "./src/provider-anthropic/index.ts"
    },
    "./anthropic/runtime": {
      "types": "./src/provider-anthropic/runtime.ts",
      "import": "./src/provider-anthropic/runtime.ts"
    },
    "./gemini": {
      "types": "./src/provider-gemini/index.ts",
      "import": "./src/provider-gemini/index.ts"
    },
    "./gemini/runtime": {
      "types": "./src/provider-gemini/runtime.ts",
      "import": "./src/provider-gemini/runtime.ts"
    },
    "./hf-transformers": {
      "types": "./src/provider-hf-transformers/index.ts",
      "import": "./src/provider-hf-transformers/index.ts"
    },
    "./hf-transformers/runtime": {
      "types": "./src/provider-hf-transformers/runtime.ts",
      "import": "./src/provider-hf-transformers/runtime.ts"
    },
    "./llamacpp": {
      "types": "./src/provider-llamacpp/index.ts",
      "import": "./src/provider-llamacpp/index.ts"
    },
    "./llamacpp/runtime": {
      "types": "./src/provider-llamacpp/runtime.ts",
      "import": "./src/provider-llamacpp/runtime.ts"
    },
    "./ollama": {
      "browser": "./src/provider-ollama/index.browser.ts",
      "types": "./src/provider-ollama/index.ts",
      "import": "./src/provider-ollama/index.ts"
    },
    "./ollama/runtime": {
      "browser": "./src/provider-ollama/runtime.browser.ts",
      "types": "./src/provider-ollama/runtime.ts",
      "import": "./src/provider-ollama/runtime.ts"
    },
    "./openai": {
      "types": "./src/provider-openai/index.ts",
      "import": "./src/provider-openai/index.ts"
    },
    "./openai/runtime": {
      "types": "./src/provider-openai/runtime.ts",
      "import": "./src/provider-openai/runtime.ts"
    },
    "./hf-inference": {
      "types": "./src/provider-hf-inference/index.ts",
      "import": "./src/provider-hf-inference/index.ts"
    },
    "./hf-inference/runtime": {
      "types": "./src/provider-hf-inference/runtime.ts",
      "import": "./src/provider-hf-inference/runtime.ts"
    },
    "./tf-mediapipe": {
      "types": "./src/provider-tf-mediapipe/index.ts",
      "import": "./src/provider-tf-mediapipe/index.ts"
    },
    "./tf-mediapipe/runtime": {
      "types": "./src/provider-tf-mediapipe/runtime.ts",
      "import": "./src/provider-tf-mediapipe/runtime.ts"
    },
    "./chrome": {
      "types": "./src/provider-chrome/index.ts",
      "import": "./src/provider-chrome/index.ts"
    },
    "./chrome/runtime": {
      "types": "./src/provider-chrome/runtime.ts",
      "import": "./src/provider-chrome/runtime.ts"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*",
    "@huggingface/transformers": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "openai": "catalog:",
    "tiktoken": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "node-llama-cpp": "catalog:",
    "@huggingface/inference": "catalog:",
    "ollama": "catalog:"
  },
  "peerDependenciesMeta": {
    "@workglow/ai": {
      "optional": false
    },
    "@workglow/job-queue": {
      "optional": false
    },
    "@workglow/storage": {
      "optional": false
    },
    "@workglow/task-graph": {
      "optional": false
    },
    "@workglow/util": {
      "optional": false
    },
    "openai": {
      "optional": true
    },
    "tiktoken": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    },
    "ollama": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "@mediapipe/tasks-text": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    },
    "@mediapipe/tasks-audio": {
      "optional": true
    },
    "@mediapipe/tasks-genai": {
      "optional": true
    },
    "@huggingface/inference": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "@huggingface/inference": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@workglow/ai": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*",
    "node-llama-cpp": "catalog:",
    "ollama": "catalog:",
    "openai": "catalog:",
    "tiktoken": "catalog:"
  }
}