{
  "name": "@workglow/debug",
  "type": "module",
  "sideEffects": false,
  "version": "0.0.115",
  "description": "Debug utilities for Workglow, including Chrome DevTools custom formatters for task graphs and workflows.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'npm:watch-*'",
    "watch-js": "SKIP_DTS=1 vite build --watch",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "vite build",
    "build-js": "SKIP_DTS=1 vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@workglow/task-graph": "workspace:*",
    "@workglow/util": "workspace:*"
  }
}
