{
  "name": "workglow",
  "type": "module",
  "version": "0.2.8",
  "repository": {
    "type": "git",
    "url": "https://github.com/workglow-dev/workglow.git",
    "directory": "packages/workglow"
  },
  "description": "Workglow meta-package: re-exports all @workglow/* packages for convenient single-import usage.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'bun:watch-*'",
    "watch-js": "bun run build.ts",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "concurrently -c 'auto' -n 'js,types' 'bun run build-js' 'bun run build-types'",
    "build-js": "bun run build.ts",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsgo",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun test"
  },
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "bun": {
        "types": "./dist/bun.d.ts",
        "import": "./dist/bun.js"
      },
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./anthropic": {
      "browser": {
        "types": "./dist/anthropic.d.ts",
        "import": "./dist/anthropic.browser.js"
      },
      "bun": {
        "types": "./dist/anthropic.d.ts",
        "import": "./dist/anthropic.bun.js"
      },
      "types": "./dist/anthropic.d.ts",
      "import": "./dist/anthropic.js"
    },
    "./anthropic/runtime": {
      "types": "./dist/anthropic-runtime.d.ts",
      "import": "./dist/anthropic-runtime.js"
    },
    "./gemini": {
      "browser": {
        "types": "./dist/google-gemini.d.ts",
        "import": "./dist/google-gemini.browser.js"
      },
      "bun": {
        "types": "./dist/google-gemini.d.ts",
        "import": "./dist/google-gemini.bun.js"
      },
      "types": "./dist/google-gemini.d.ts",
      "import": "./dist/google-gemini.js"
    },
    "./gemini/runtime": {
      "types": "./dist/google-gemini-runtime.d.ts",
      "import": "./dist/google-gemini-runtime.js"
    },
    "./hf-transformers": {
      "browser": {
        "types": "./dist/hf-transformers.d.ts",
        "import": "./dist/hf-transformers.browser.js"
      },
      "bun": {
        "types": "./dist/hf-transformers.d.ts",
        "import": "./dist/hf-transformers.bun.js"
      },
      "types": "./dist/hf-transformers.d.ts",
      "import": "./dist/hf-transformers.js"
    },
    "./hf-transformers/runtime": {
      "types": "./dist/hf-transformers-runtime.d.ts",
      "import": "./dist/hf-transformers-runtime.js"
    },
    "./ollama": {
      "browser": {
        "types": "./dist/ollama.d.ts",
        "import": "./dist/ollama.browser.js"
      },
      "bun": {
        "types": "./dist/ollama.d.ts",
        "import": "./dist/ollama.bun.js"
      },
      "types": "./dist/ollama.d.ts",
      "import": "./dist/ollama.js"
    },
    "./ollama/runtime": {
      "types": "./dist/ollama-runtime.d.ts",
      "import": "./dist/ollama-runtime.js"
    },
    "./openai": {
      "browser": {
        "types": "./dist/openai.d.ts",
        "import": "./dist/openai.browser.js"
      },
      "bun": {
        "types": "./dist/openai.d.ts",
        "import": "./dist/openai.bun.js"
      },
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js"
    },
    "./openai/runtime": {
      "types": "./dist/openai-runtime.d.ts",
      "import": "./dist/openai-runtime.js"
    },
    "./tf-mediapipe": {
      "types": "./dist/tf-mediapipe.d.ts",
      "import": "./dist/tf-mediapipe.js"
    },
    "./tf-mediapipe/runtime": {
      "types": "./dist/tf-mediapipe-runtime.d.ts",
      "import": "./dist/tf-mediapipe-runtime.js"
    },
    "./worker": {
      "react-native": {
        "types": "./dist/worker-browser.d.ts",
        "import": "./dist/worker-browser.js"
      },
      "browser": {
        "types": "./dist/worker-browser.d.ts",
        "import": "./dist/worker-browser.js"
      },
      "bun": {
        "types": "./dist/worker-bun.d.ts",
        "import": "./dist/worker-bun.js"
      },
      "types": "./dist/worker-browser.d.ts",
      "import": "./dist/worker-node.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "tslog": "^4.9.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "openai": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "ollama": "catalog:",
    "node-llama-cpp": "catalog:",
    "@sqlite.org/sqlite-wasm": "catalog:",
    "better-sqlite3": "catalog:",
    "pg": "catalog:",
    "@supabase/supabase-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "@mediapipe/tasks-text": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    },
    "@mediapipe/tasks-audio": {
      "optional": true
    },
    "@mediapipe/tasks-genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "ollama": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    },
    "@sqlite.org/sqlite-wasm": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  }
}
