{
  "name": "workglow",
  "type": "module",
  "version": "0.0.115",
  "description": "Workglow meta-package: re-exports all @workglow/* packages for convenient single-import usage.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'npm:watch-*'",
    "watch-js": "SKIP_DTS=1 vite build --watch",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "vite build",
    "build-js": "SKIP_DTS=1 vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/node.js"
    },
    "./anthropic": {
      "browser": "./dist/anthropic.browser.js",
      "types": "./dist/anthropic.d.ts",
      "import": "./dist/anthropic.js"
    },
    "./google-gemini": {
      "browser": "./dist/google-gemini.browser.js",
      "types": "./dist/google-gemini.d.ts",
      "import": "./dist/google-gemini.js"
    },
    "./hf-transformers": {
      "browser": "./dist/hf-transformers.browser.js",
      "types": "./dist/hf-transformers.d.ts",
      "import": "./dist/hf-transformers.js"
    },
    "./ollama": {
      "browser": "./dist/ollama.browser.js",
      "types": "./dist/ollama.d.ts",
      "import": "./dist/ollama.js"
    },
    "./openai": {
      "browser": "./dist/openai.browser.js",
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js"
    },
    "./tf-mediapipe": {
      "browser": "./dist/tf-mediapipe.js",
      "types": "./dist/tf-mediapipe.d.ts"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/debug": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/sqlite": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "tslog": "^4.9.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "openai": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "ollama": "catalog:",
    "node-llama-cpp": "catalog:",
    "@sqlite.org/sqlite-wasm": "catalog:",
    "better-sqlite3": "catalog:",
    "pg": "catalog:",
    "@supabase/supabase-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "@mediapipe/tasks-text": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    },
    "@mediapipe/tasks-audio": {
      "optional": true
    },
    "@mediapipe/tasks-genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "ollama": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    },
    "@sqlite.org/sqlite-wasm": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  }
}
