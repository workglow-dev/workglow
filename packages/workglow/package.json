{
  "name": "workglow",
  "type": "module",
  "version": "0.0.121",
  "description": "Workglow meta-package: re-exports all @workglow/* packages for convenient single-import usage.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'bun:watch-*'",
    "watch-js": "concurrently -c 'auto' -n 'browser,node,bun' 'bun run watch-browser' 'bun run watch-node' 'bun run watch-bun'",
    "watch-browser": "bun build --splitting --watch --no-clear-screen --target=browser --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/browser.ts ./src/anthropic.browser.ts ./src/google-gemini.browser.ts ./src/hf-transformers.browser.ts ./src/ollama.browser.ts ./src/openai.browser.ts ./src/tf-mediapipe.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "watch-node": "bun build --splitting --watch --no-clear-screen --target=node --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/node.ts ./src/anthropic.ts ./src/google-gemini.ts ./src/hf-transformers.ts ./src/ollama.ts ./src/openai.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "watch-bun": "bun build --splitting --watch --no-clear-screen --target=bun --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/bun.ts ./src/anthropic.bun.ts ./src/google-gemini.bun.ts ./src/hf-transformers.bun.ts ./src/ollama.bun.ts ./src/openai.bun.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "concurrently -c 'auto' -n 'browser,node,bun,types' 'bun run build-browser' 'bun run build-node' 'bun run build-bun' 'bun run build-types'",
    "build-js": "concurrently -c 'auto' -n 'browser,node,bun' 'bun run build-browser' 'bun run build-node' 'bun run build-bun'",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-browser": "bun build --splitting --target=browser --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/browser.ts ./src/anthropic.browser.ts ./src/google-gemini.browser.ts ./src/hf-transformers.browser.ts ./src/ollama.browser.ts ./src/openai.browser.ts ./src/tf-mediapipe.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "build-node": "bun build --splitting --target=node --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/node.ts ./src/anthropic.ts ./src/google-gemini.ts ./src/hf-transformers.ts ./src/ollama.ts ./src/openai.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "build-bun": "bun build --splitting --target=bun --sourcemap=external --packages=external --root ./src --outdir ./dist ./src/bun.ts ./src/anthropic.bun.ts ./src/google-gemini.bun.ts ./src/hf-transformers.bun.ts ./src/ollama.bun.ts ./src/openai.bun.ts ./src/anthropic-runtime.ts ./src/google-gemini-runtime.ts ./src/openai-runtime.ts ./src/ollama-runtime.ts ./src/tf-mediapipe-runtime.ts ./src/hf-transformers-runtime.ts",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsgo",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun test"
  },
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "bun": "./dist/bun.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/node.js"
    },
    "./anthropic": {
      "browser": "./dist/anthropic.browser.js",
      "bun": "./dist/anthropic.bun.js",
      "types": "./dist/anthropic.d.ts",
      "import": "./dist/anthropic.js"
    },
    "./anthropic/runtime": {
      "types": "./dist/anthropic-runtime.d.ts",
      "import": "./dist/anthropic-runtime.js"
    },
    "./gemini": {
      "browser": "./dist/google-gemini.browser.js",
      "bun": "./dist/google-gemini.bun.js",
      "types": "./dist/google-gemini.d.ts",
      "import": "./dist/google-gemini.js"
    },
    "./gemini/runtime": {
      "types": "./dist/google-gemini-runtime.d.ts",
      "import": "./dist/google-gemini-runtime.js"
    },
    "./hf-transformers": {
      "browser": "./dist/hf-transformers.browser.js",
      "bun": "./dist/hf-transformers.bun.js",
      "types": "./dist/hf-transformers.d.ts",
      "import": "./dist/hf-transformers.js"
    },
    "./hf-transformers/runtime": {
      "types": "./dist/hf-transformers-runtime.d.ts",
      "import": "./dist/hf-transformers-runtime.js"
    },
    "./ollama": {
      "browser": "./dist/ollama.browser.js",
      "bun": "./dist/ollama.bun.js",
      "types": "./dist/ollama.d.ts",
      "import": "./dist/ollama.js"
    },
    "./ollama/runtime": {
      "types": "./dist/ollama-runtime.d.ts",
      "import": "./dist/ollama-runtime.js"
    },
    "./openai": {
      "browser": "./dist/openai.browser.js",
      "bun": "./dist/openai.bun.js",
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js"
    },
    "./openai/runtime": {
      "types": "./dist/openai-runtime.d.ts",
      "import": "./dist/openai-runtime.js"
    },
    "./tf-mediapipe": {
      "types": "./dist/tf-mediapipe.d.ts",
      "import": "./dist/tf-mediapipe.js"
    },
    "./tf-mediapipe/runtime": {
      "types": "./dist/tf-mediapipe-runtime.d.ts",
      "import": "./dist/tf-mediapipe-runtime.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/debug": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/sqlite": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "tslog": "^4.9.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@mediapipe/tasks-text": "catalog:",
    "@mediapipe/tasks-vision": "catalog:",
    "@mediapipe/tasks-audio": "catalog:",
    "@mediapipe/tasks-genai": "catalog:",
    "openai": "catalog:",
    "@anthropic-ai/sdk": "catalog:",
    "@google/generative-ai": "catalog:",
    "ollama": "catalog:",
    "node-llama-cpp": "catalog:",
    "@sqlite.org/sqlite-wasm": "catalog:",
    "better-sqlite3": "catalog:",
    "pg": "catalog:",
    "@supabase/supabase-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "@mediapipe/tasks-text": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    },
    "@mediapipe/tasks-audio": {
      "optional": true
    },
    "@mediapipe/tasks-genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "ollama": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    },
    "@sqlite.org/sqlite-wasm": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  }
}