{
  "name": "@workglow/test",
  "type": "module",
  "version": "0.0.115",
  "description": "Testing utilities and test suites for Workglow packages, providing comprehensive testing infrastructure.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'npm:watch-*'",
    "watch-js": "SKIP_DTS=1 vite build --watch",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "vite build",
    "build-js": "SKIP_DTS=1 vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "peerDependencies": {
    "@workglow/ai": "workspace:*",
    "@workglow/ai-provider": "workspace:*",
    "@workglow/knowledge-base": "workspace:*",
    "@workglow/job-queue": "workspace:*",
    "@workglow/storage": "workspace:*",
    "@workglow/task-graph": "workspace:*",
    "@workglow/tasks": "workspace:*",
    "@workglow/util": "workspace:*",
    "@workglow/sqlite": "workspace:*",
    "@electric-sql/pglite": "^0.3.15",
    "pg": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:"
  },
  "peerDependenciesMeta": {
    "@workglow/ai": {
      "optional": false
    },
    "@workglow/ai-provider": {
      "optional": false
    },
    "@workglow/knowledge-base": {
      "optional": false
    },
    "@workglow/job-queue": {
      "optional": false
    },
    "@workglow/storage": {
      "optional": false
    },
    "@workglow/task-graph": {
      "optional": false
    },
    "@workglow/tasks": {
      "optional": false
    },
    "@workglow/util": {
      "optional": false
    },
    "@workglow/sqlite": {
      "optional": false
    },
    "@modelcontextprotocol/sdk": {
      "optional": false
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "catalog:",
