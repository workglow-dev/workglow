{
  "name": "@workglow/storage",
  "type": "module",
  "version": "0.0.115",
  "description": "Storage abstraction layer for Workglow, supporting IndexedDB, PostgreSQL, and Supabase with unified interfaces.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'npm:watch-*'",
    "watch-js": "SKIP_DTS=1 vite build --watch",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "vite build",
    "build-js": "SKIP_DTS=1 vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@workglow/sqlite": "workspace:*",
    "@workglow/util": "workspace:*",
    "pg": "catalog:",
    "@supabase/supabase-js": "catalog:"
  },
  "peerDependenciesMeta": {
    "@workglow/sqlite": {
      "optional": false
    },
    "@workglow/util": {
      "optional": false
    }
  },
  "devDependencies": {
    "@workglow/sqlite": "workspace:*",
    "@workglow/util": "workspace:*",
    "pg": "catalog:",
    "@types/pg": "^8.18.0",
    "@supabase/supabase-js": "catalog:",
    "fake-indexeddb": "^6.2.4"
  },
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
