{
  "name": "@workglow/sqlite",
  "type": "module",
  "version": "0.0.115",
  "description": "SQLite database providing cross-platform database support for browser, Node.js, and Bun environments.",
  "scripts": {
    "watch": "concurrently -c 'auto' 'npm:watch-*'",
    "watch-js": "SKIP_DTS=1 vite build --watch",
    "watch-types": "tsc --watch --preserveWatchOutput",
    "build-package": "vite build",
    "build-js": "SKIP_DTS=1 vite build",
    "build-clean": "rm -fr dist/* tsconfig.tsbuildinfo",
    "build-types": "rm -f tsconfig.tsbuildinfo && tsc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@sqlite.org/sqlite-wasm": "catalog:",
    "better-sqlite3": "catalog:"
  },
  "peerDependenciesMeta": {
    "@sqlite.org/sqlite-wasm": {
      "optional": false
    },
    "better-sqlite3": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "sideEffects": true,
  "exports": {
    ".": {
      "react-native": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "types": "./dist/types.d.ts",
      "import": "./dist/node.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./react-native": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {}
}
