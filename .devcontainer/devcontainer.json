{
  "name": "Workglow-libs",
  "build": { "dockerfile": "./Dockerfile" },

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      },
      "extensions": [
        "oven.bun-vscode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "zardoy.ts-essential-plugins",
        "bradlc.vscode-tailwindcss",
        "vscode-icons-team.vscode-icons"
      ]
    }
  },

  // web example uses port 3800
  "forwardPorts": [3800],

  "remoteUser": "node",

  "postCreateCommand": "cat .devcontainer/custom-prompt.sh >> ~/.zshrc || true && bun --version && node --version && npm --version && chmod +x .devcontainer/*.sh 2>/dev/null || true",
  "postAttachCommand": "bash .devcontainer/post-attach.sh",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "lfs": true
    },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  }
}
